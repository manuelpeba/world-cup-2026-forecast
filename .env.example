# Environment configuration for world-cup-2026-forecast

# Random seed for simulations
SIMULATION_RANDOM_SEED=42

# Number of parallel workers for Monte Carlo simulations
SIMULATION_WORKERS=4

# Number of tournament simulations
NUM_SIMULATIONS=100000

# Data directories
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_OUTPUT_DIR=data/outputs

# Model configuration
MODEL_TYPE=logistic_regression

# Optional API keys for data ingestion
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_KEY=